NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Must be a public HTTPS URL after deployment. Telegram cannot reach localhost.
NEXT_PUBLIC_APP_URL=https://your-public-domain.com

# Telegram QR login
TELEGRAM_BOT_USERNAME=qltrade_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Market alert worker
# Prefer Hermes if it already forwards to Telegram/Slack.
HERMES_SEND_CMD=/Users/hang/.hermes/hermes-agent/venv/bin/hermes
HERMES_SEND_TARGET=telegram
HERMES_WEBHOOK_URL=

# Optional direct Telegram fallback if Hermes is not available for this worker.
TELEGRAM_CHAT_ID=

MARKET_ALERTS_CONFIG=market-alerts.json
MARKET_ALERT_STATE=.market-alert-state.json
MARKET_ALERT_INTERVAL_SECONDS=60
MARKET_ALERT_DRY_RUN=false
MARKET_ALERT_RUN_ONCE=false
